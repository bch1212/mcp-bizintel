# Yelp Fusion API key — used by search/details tools.
# Without this, search tools degrade to OSM-style fallback (Nominatim/Overpass).
YELP_API_KEY=your_key_here

# Comma-separated paid keys, e.g. "k_pro_alice,k_pro_bob"
BIZINTEL_PRO_KEYS=

# Override the default dev key (free tier, 20 calls/day)
BIZINTEL_DEV_KEY=bizintel-dev-key-001

# Path to SQLite db (defaults to ./bizintel.db inside container)
BIZINTEL_DB_PATH=bizintel.db

# Server port
PORT=8000
